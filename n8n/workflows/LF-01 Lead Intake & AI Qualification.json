    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? {};\n\nfunction clean(value) {\n  return value === undefined || value === null\n    ? \"\"\n    : String(value).trim();\n}\n\nfunction normalizePhone(value) {\n  return clean(value).replace(/[\\s()-]/g, \"\");\n}\n\nconst requiredFields = [\n  \"external_id\",\n  \"company_name\",\n  \"first_name\",\n  \"last_name\",\n  \"email\",\n  \"title\",\n  \"description\",\n];\n\nconst missingFields = requiredFields.filter(\n  (field) => clean(body[field]) === \"\"\n);\n\nif (missingFields.length > 0) {\n  throw new Error(\n    `Missing required fields: ${missingFields.join(\", \")}`\n  );\n}\n\nconst externalId = clean(body.external_id);\n\nif (!/^[A-Za-z0-9._:-]{3,100}$/.test(externalId)) {\n  throw new Error(\n    \"external_id must contain 3-100 letters, numbers, dots, underscores, colons or hyphens\"\n  );\n}\n\nconst email = clean(body.email).toLowerCase();\n\nif (!/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email)) {\n  throw new Error(\"Invalid email address\");\n}\n\nconst estimatedValue = Number(body.estimated_value ?? 0);\n\nif (!Number.isFinite(estimatedValue) || estimatedValue < 0) {\n  throw new Error(\n    \"estimated_value must be a non-negative number\"\n  );\n}\n\nreturn [\n  {\n    json: {\n      company: {\n        name: clean(body.company_name),\n        industry: clean(body.industry),\n        website: clean(body.website),\n        phone: normalizePhone(body.company_phone),\n      },\n      contact: {\n        first_name: clean(body.first_name),\n        last_name: clean(body.last_name),\n        email,\n        phone: normalizePhone(body.phone),\n        job_title: clean(body.job_title),\n      },\n      lead: {\n        external_id: externalId,\n        title: clean(body.title),\n        description: clean(body.description),\n        status: \"new\",\n        source: clean(body.source || \"website_form\")\n          .toLowerCase()\n          .replace(/\\s+/g, \"_\"),\n        estimated_value: estimatedValue,\n        currency: clean(body.currency || \"MAD\").toUpperCase(),\n      },\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
