    {
      "parameters": {
        "promptType": "define",
        "text": "=Qualify the following inbound lead.\n\nCompany name:\n{{ $('Normalize & Validate').item.json.company.name }}\n\nIndustry:\n{{ $('Normalize & Validate').item.json.company.industry }}\n\nLead title:\n{{ $('Normalize & Validate').item.json.lead.title }}\n\nLead description:\n{{ $('Normalize & Validate').item.json.lead.description }}\n\nEstimated commercial value:\n{{ $('Normalize & Validate').item.json.lead.estimated_value }}\n{{ $('Normalize & Validate').item.json.lead.currency }}\n\nLead source:\n{{ $('Normalize & Validate').item.json.lead.source }}\n\nReturn exactly this JSON structure:\n\n{\n  \"score\": 0,\n  \"summary\": \"Résumé professionnel en français\",\n  \"recommended_action\": \"Prochaine action concrète en français\"\n}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict B2B lead qualification engine for an AI automation company.  Your task is to evaluate whether an inbound request represents a valuable and actionable opportunity for automation, API integration, AI workflows, or business process improvement.  Scoring rubric: - Business need clarity: 0 to 30 points. - Fit with AI automation services: 0 to 30 points. - Budget or commercial value: 0 to 20 points. - Urgency and actionability: 0 to 20 points.  Rules: - The final score must be an integer from 0 to 100. - Do not invent information. - Missing information must reduce the score. - Write the summary and recommended action in French. - Keep each text concise and professional. - Return only valid JSON. - Do not use Markdown. - Do not use code fences. - Do not add fields outside the required JSON structure."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        2512,
        32
      ],
      "id": "4ca01b59-a775-480c-8f0d-596ca1892323",
      "name": "AI Qualification"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "gpt-5.6-luna",
          "mode": "list",
          "cachedResultName": "gpt-5.6-luna"
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        2448,
        240
      ],
      "id": "27f01cbd-ccb4-4693-b855-72fc76fc7987",
      "name": "OpenAI Chat Model"
    },
    {
      "parameters": {
        "jsCode": "const rawOutput =\n  $json.text ??\n  $json.output ??\n  $json.response ??\n  $json;\n\nlet parsed;\n\nif (\n  typeof rawOutput === \"object\" &&\n  rawOutput !== null &&\n  !Array.isArray(rawOutput)\n) {\n  parsed = rawOutput;\n} else {\n  const cleanedOutput = String(rawOutput)\n    .trim()\n    .replace(/^```(?:json)?\\s*/i, \"\")\n    .replace(/\\s*```$/i, \"\");\n\n  try {\n    parsed = JSON.parse(cleanedOutput);\n  } catch {\n    throw new Error(\n      `AI returned invalid JSON: ${cleanedOutput}`\n    );\n  }\n}\n\nconst score = Number(parsed.score);\n\nif (\n  !Number.isInteger(score) ||\n  score < 0 ||\n  score > 100\n) {\n  throw new Error(\n    \"AI score must be an integer between 0 and 100\"\n  );\n}\n\nconst summary = String(parsed.summary ?? \"\").trim();\nconst recommendedAction = String(\n  parsed.recommended_action ?? \"\"\n).trim();\n\nif (!summary) {\n  throw new Error(\"AI summary is missing\");\n}\n\nif (!recommendedAction) {\n  throw new Error(\"AI recommended_action is missing\");\n}\n\n// Ces valeurs sont calculées par le code,\n// pas choisies librement par l'IA.\nconst priority =\n  score >= 70\n    ? \"high\"\n    : score >= 40\n      ? \"medium\"\n      : \"low\";\n\nconst status = score >= 70 ? \"qualified\" : \"new\";\n\nreturn [\n  {\n    json: {\n      score,\n      priority,\n      status,\n      summary: summary.slice(0, 500),\n      recommended_action: recommendedAction.slice(0, 500),\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2864,
        32
      ],
      "id": "651e0c14-600b-4b79-903c-739f82feab15",
      "name": "Parse AI Qualification"
    },
    {
      "parameters": {
        "jsCode": "const ai = $input.first().json;\n\nconst normalizedLead =\n  $(\"Normalize & Validate\").first().json.lead;\n\nconst resolvedContact =\n  $(\"Resolve Contact\").first().json;\n\nconst enrichedDescription = [\n  normalizedLead.description,\n  \"\",\n  \"AI Qualification\",\n  `Score: ${ai.score}/100`,\n  `Priority: ${ai.priority}`,\n  `Summary: ${ai.summary}`,\n  `Recommended action: ${ai.recommended_action}`,\n]\n  .join(\"\\n\")\n  .slice(0, 5000);\n\nreturn [\n  {\n    json: {\n      company_id: resolvedContact.company_id,\n      contact_id: resolvedContact.contact_id,\n      external_id: normalizedLead.external_id,\n      title: normalizedLead.title,\n      description: enrichedDescription,\n      status: ai.status,\n      source: normalizedLead.source,\n      estimated_value: normalizedLead.estimated_value,\n      currency: normalizedLead.currency,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3072,
        32
      ],
      "id": "11c171c8-4c4f-43d8-8131-a7db58a08164",
      "name": "Build Lead Payload"
    }
